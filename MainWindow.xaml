<Window x:Class="AtlasSpriteRevertTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:AtlasSpriteRevertTool.Converters"
        Title="Atlas Sprite Revert Tool"
        Width="1280" Height="720"
        MinWidth="960" MinHeight="540"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <conv:HexColorConverter x:Key="HexColor"/>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>

        <!-- ══════════════════════════════════════════
             PALETTE  —  Deep Sage-Mint
             ══════════════════════════════════════════
             Window bg : #D6EDE6
             Surface   : #E8F3EF  /  #EEF6F2  /  #F3F9F7
             Border    : #8BBFB4  /  #5DA89A
             Text      : #0D1F1C (primary) / #2A4840 (sec) / #537A72 (muted)
             Accent    : #0A7A5C → #13A87C  (deep mint/teal)
             Ghost bg  : #D0E8E0
             Danger    : #C84040
        -->

        <!-- ── Card / Panel ── -->
        <Style x:Key="GlassPanel" TargetType="Border">
            <Setter Property="Background" Value="#EEF6F2"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="BorderBrush" Value="#8BBFB4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#4A9888" BlurRadius="14" Opacity="0.15" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Custom Scrollbar (mint, slim) ── -->
        <Style x:Key="MintScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Opacity="0" Focusable="False"
                                                  Height="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="ThumbBd"
                                                        Background="#8EC8BA"
                                                        CornerRadius="3"
                                                        Margin="1,2">
                                                    <VisualStateManager.VisualStateGroups>
                                                        <VisualStateGroup x:Name="CommonStates">
                                                            <VisualState x:Name="Normal"/>
                                                            <VisualState x:Name="MouseOver">
                                                                <Storyboard>
                                                                    <ColorAnimation Storyboard.TargetName="ThumbBd"
                                                                                    Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                                    To="#0AA87C" Duration="0:0:0.15"/>
                                                                </Storyboard>
                                                            </VisualState>
                                                        </VisualStateGroup>
                                                    </VisualStateManager.VisualStateGroups>
                                                </Border>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Opacity="0" Focusable="False"
                                                  Height="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ScrollViewer using mint scrollbar -->
        <Style x:Key="MintScrollViewer" TargetType="ScrollViewer">
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter Grid.Column="0"
                                                    CanContentScroll="{TemplateBinding CanContentScroll}"/>
                            <ScrollBar Grid.Column="1"
                                       x:Name="PART_VerticalScrollBar"
                                       Style="{StaticResource MintScrollBar}"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Section Label ── -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#0A7A5C"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <!-- ── Input TextBox ── -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#DCF0EA"/>
            <Setter Property="Foreground" Value="#0D1F1C"/>
            <Setter Property="BorderBrush" Value="#8BBFB4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#0A7A5C"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#5DA89A"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#0A7A5C"/>
                                <Setter TargetName="Bd" Property="Background" Value="#C8E8DC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Accent / Primary Button ── -->
        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#0A7A5C" Offset="0"/>
                        <GradientStop Color="#13A87C" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect Color="#0A8A6A" BlurRadius="14" Opacity="0.35" ShadowDepth="2"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.72"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Ghost / Secondary Button ── -->
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="#B8D8CC"/>
            <Setter Property="Foreground" Value="#2A4840"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="#8BBFB4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#A8D0C4"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#086048"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.70"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Danger Button ── -->
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Background" Value="#D0E8E0"/>
            <Setter Property="Foreground" Value="#2A4840"/>
            <Setter Property="BorderBrush" Value="#8BBFB4"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E8D0D0"/>
                    <Setter Property="BorderBrush" Value="#A83030"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── TitleBar Icon Button ── -->
        <Style x:Key="TitleBarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#40605A"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#A8D0C4"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.60"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Results ListView Row ── -->
        <Style x:Key="ResultRow" TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#1A3530"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Margin="0,1"
                                CornerRadius="3"
                                Padding="8,5">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#C8E8DD"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#A8D0C4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Progress Bar ── -->
        <Style x:Key="GlowProgress" TargetType="ProgressBar">
            <Setter Property="Background" Value="#B8D8CC"/>
            <Setter Property="Foreground">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#0A8A6A" Offset="0"/>
                        <GradientStop Color="#086048" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Height" Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="2"
                                Height="{TemplateBinding Height}">
                            <Border x:Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="2">
                                <Border.Effect>
                                    <DropShadowEffect Color="#086048" BlurRadius="6" Opacity="0.60" ShadowDepth="0"/>
                                </Border.Effect>
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── File ListBox Item ── -->
        <Style x:Key="FileListItem" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#2A4840"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#C8E8DD"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#A8D0C4"/>
                                <Setter Property="Foreground" Value="#086048"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- ROOT -->
    <Grid>

        <!-- ── Outer shell: square with thin mint border ── -->
        <Border x:Name="MainBorder" Margin="10" CornerRadius="2"
                Background="#A8D0C4">
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#4A8A7A" Offset="0"/>
                    <GradientStop Color="#6AA89A" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Border.BorderThickness>1.5</Border.BorderThickness>
            <Border.Effect>
                <DropShadowEffect BlurRadius="36" Opacity="0.22" ShadowDepth="0" Color="#086048"/>
            </Border.Effect>

            <Grid ClipToBounds="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="52"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="30"/>
                </Grid.RowDefinitions>

                <!-- Top mint accent bar -->
                <Rectangle Grid.RowSpan="3" VerticalAlignment="Top" Height="3">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#086048" Offset="0"/>
                            <GradientStop Color="#0A8A6A" Offset="0.6"/>
                            <GradientStop Color="#5DC8A8" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <!-- Left mint accent bar -->
                <Rectangle Grid.RowSpan="3" HorizontalAlignment="Left" Width="3">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#086048" Offset="0"/>
                            <GradientStop Color="#5DC8A8" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <!-- ══════════ TITLE BAR ══════════ -->
                <Border Grid.Row="0"
                        Background="#D6EDE6"
                        BorderBrush="#6AA89A"
                        BorderThickness="0,0,0,1"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Logo + Title -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal"
                                    VerticalAlignment="Center" Margin="20,0,0,0">
                            <!-- Square mint logo mark -->
                            <Border Width="22" Height="22" CornerRadius="3"
                                    Margin="0,0,10,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#086048" Offset="0"/>
                                        <GradientStop Color="#0A8A6A" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="A" Foreground="White"
                                           FontFamily="Segoe UI"
                                           FontWeight="Bold"
                                           FontSize="13"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Atlas Sprite Revert Tool"
                                       Foreground="#0D1F1C"
                                       FontFamily="Segoe UI"
                                       FontWeight="SemiBold"
                                       FontSize="14"
                                       VerticalAlignment="Center"/>
                            <!-- Separator -->
                            <Rectangle Width="1" Height="16" Fill="#6AA89A" Margin="12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Unity AssetRipper Extractor"
                                       Foreground="#40605A"
                                       FontFamily="Segoe UI"
                                       FontSize="11.5"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Window controls -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                    Margin="0,0,10,0" VerticalAlignment="Center">
                            <Button x:Name="BtnMinimize"
                                    Content="&#x2014;"
                                    Style="{StaticResource TitleBarButton}"
                                    Click="MinimizeWindow"
                                    ToolTip="Minimize"/>
                            <Button x:Name="BtnFullscreen"
                                    Content="&#x26F6;"
                                    Style="{StaticResource TitleBarButton}"
                                    Click="ToggleFullscreen"
                                    ToolTip="Toggle Fullscreen"
                                    Margin="2,0"/>
                            <Button x:Name="BtnClose"
                                    Content="&#x2715;"
                                    Style="{StaticResource DangerButton}"
                                    Padding="0"
                                    Width="34" Height="34"
                                    Click="CloseWindow"
                                    ToolTip="Close"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ══════════ MAIN CONTENT ══════════ -->
                <Grid x:Name="MainContent" Grid.Row="1" Margin="16,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="330"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ── LEFT PANEL (scrollable) ── -->
                    <ScrollViewer Grid.Column="0"
                                  Style="{StaticResource MintScrollViewer}"
                                  Padding="0,0,4,0">
                        <StackPanel>

                        <!-- Search Folder -->
                        <Border Style="{StaticResource GlassPanel}" Padding="16,14" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="📁  SEARCH FOLDER" Style="{StaticResource SectionLabel}"/>
                                <TextBlock Text="Atlas texture source directory"
                                           Foreground="#40605A" FontSize="10.5"
                                           FontFamily="Segoe UI" Margin="0,0,0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TxSearchFolder"
                                             Style="{StaticResource DarkTextBox}"
                                             Text="{Binding SearchFolder, UpdateSourceTrigger=PropertyChanged}"
                                             IsReadOnly="True"/>
                                    <Button Grid.Column="2" Content="Browse"
                                            Style="{StaticResource GhostButton}"
                                            Click="BrowseSearchFolder"/>
                                </Grid>
                                <Button Content="⚡  Index Folder"
                                        Style="{StaticResource AccentButton}"
                                        Margin="0,10,0,0"
                                        IsEnabled="{Binding IsIdle}"
                                        Click="IndexFolder"/>
                                <Border Margin="0,10,0,0"
                                        Background="#C8E8DD"
                                        CornerRadius="4" Padding="10,7"
                                        BorderBrush="#6AA89A" BorderThickness="1">
                                    <TextBlock Text="{Binding CacheInfo}"
                                               Foreground="#40605A"
                                               FontFamily="Consolas"
                                               FontSize="11"
                                               TextWrapping="Wrap"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Output Settings -->
                        <Border Style="{StaticResource GlassPanel}" Padding="16,14" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="💾  OUTPUT SETTINGS" Style="{StaticResource SectionLabel}"/>

                                <TextBlock Text="Destination folder"
                                           Foreground="#40605A" FontSize="10.5"
                                           FontFamily="Segoe UI" Margin="0,0,0,6"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Style="{StaticResource DarkTextBox}"
                                             Text="{Binding OutputFolder, UpdateSourceTrigger=PropertyChanged}"
                                             IsReadOnly="True"/>
                                    <Button Grid.Column="2" Content="Browse"
                                            Style="{StaticResource GhostButton}"
                                            Click="BrowseOutputFolder"/>
                                </Grid>

                                <TextBlock Text="Name template"
                                           Foreground="#40605A" FontSize="10.5"
                                           FontFamily="Segoe UI" Margin="0,12,0,6"/>
                                <TextBox Style="{StaticResource DarkTextBox}"
                                         Text="{Binding OutputNameTemplate, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Text="Tokens:  {name}  {index}  {guid}"
                                           Foreground="#4A8A7A"
                                           FontFamily="Consolas"
                                           FontSize="10.5"
                                           Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Asset Files -->
                        <Border Style="{StaticResource GlassPanel}" Padding="16,14" Margin="0,0,0,12"
                                MinHeight="180">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="160"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="🗂  ASSET FILES" Style="{StaticResource SectionLabel}"/>
                                    <Border Grid.Column="1" Background="#A8D0C4"
                                            CornerRadius="10" Padding="8,2">
                                        <TextBlock Text="{Binding AssetFiles.Count, StringFormat='{}{0} files'}"
                                                   Foreground="#086048"
                                                   FontFamily="Segoe UI"
                                                   FontWeight="SemiBold"
                                                   FontSize="10.5"/>
                                    </Border>
                                </Grid>

                                <!-- Drop zone -->
                                <Border Grid.Row="2"
                                        Background="#C8E8DD"
                                        CornerRadius="4"
                                        BorderBrush="#6AA89A"
                                        BorderThickness="1"
                                        AllowDrop="True"
                                        Drop="AssetFileList_Drop"
                                        DragOver="AssetFileList_DragOver">
                                    <Grid>
                                        <StackPanel HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Opacity="0.50">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding AssetFiles.Count}" Value="0">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <TextBlock Text="📄" FontSize="28"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,0,0,8"/>
                                            <TextBlock Text="Drop .asset files here"
                                                       Foreground="#40605A"
                                                       FontFamily="Segoe UI"
                                                       FontSize="12"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                        <ListBox x:Name="AssetListBox"
                                                 ItemsSource="{Binding AssetFiles}"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 ItemContainerStyle="{StaticResource FileListItem}"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                 VirtualizingPanel.IsVirtualizing="True"
                                                 Padding="4"/>
                                    </Grid>
                                </Border>

                                <WrapPanel Grid.Row="4" Orientation="Horizontal" ItemWidth="Auto">
                                    <Button Content="＋  Add Files"
                                            Style="{StaticResource GhostButton}"
                                            Click="AddAssetFiles" Margin="0,0,6,6"/>
                                    <Button Content="📁  Add Folder"
                                            Style="{StaticResource GhostButton}"
                                            Click="AddAssetFolder" Margin="0,0,6,6"/>
                                    <Button Content="⊗  Clear"
                                            Style="{StaticResource DangerButton}"
                                            Click="ClearAssetFiles" Margin="0,0,0,6"/>
                                </WrapPanel>
                            </Grid>
                        </Border>

                        <!-- Extract Button -->
                        <Button Content="▶  Extract Sprites"
                                Style="{StaticResource AccentButton}"
                                FontSize="15"
                                Padding="0,14"
                                IsEnabled="{Binding IsIdle}"
                                Click="ExtractSprites"
                                Margin="0,0,0,4"/>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- ── RIGHT PANEL ── -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Progress header -->
                        <Border Grid.Row="0" Style="{StaticResource GlassPanel}" Padding="16,14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="📊  EXTRACTION LOG" Style="{StaticResource SectionLabel}"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <TextBlock Text="{Binding Results.Count, StringFormat='{}{0} entries'}"
                                                   Foreground="#6AA89A"
                                                   FontFamily="Segoe UI"
                                                   FontSize="11"
                                                   Margin="0,0,10,0"
                                                   VerticalAlignment="Center"/>
                                        <Button Content="Clear Log"
                                                Style="{StaticResource GhostButton}"
                                                Padding="8,4"
                                                FontSize="11"
                                                Click="ClearResults"/>
                                    </StackPanel>
                                </Grid>

                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ProgressBar Style="{StaticResource GlowProgress}"
                                                 Value="{Binding ProgressValue}"
                                                 Maximum="{Binding ProgressMax}"
                                                 VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding StatusText}"
                                               Foreground="#2A4840"
                                               FontFamily="Segoe UI"
                                               FontSize="11"
                                               VerticalAlignment="Center"
                                               MaxWidth="300"
                                               TextTrimming="CharacterEllipsis"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Results ListView -->
                        <Border Grid.Row="2" Style="{StaticResource GlassPanel}" Padding="0">
                            <ListView x:Name="ResultsList"
                                      ItemsSource="{Binding Results}"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      ItemContainerStyle="{StaticResource ResultRow}"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      Padding="10,8">
                                <ListView.View>
                                    <GridView>
                                        <GridView.ColumnHeaderContainerStyle>
                                            <Style TargetType="GridViewColumnHeader">
                                                <Setter Property="Background" Value="#C8E8DD"/>
                                                <Setter Property="Foreground" Value="#086048"/>
                                                <Setter Property="FontFamily" Value="Segoe UI"/>
                                                <Setter Property="FontSize" Value="10.5"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Padding" Value="8,7"/>
                                            </Style>
                                        </GridView.ColumnHeaderContainerStyle>
                                        <GridViewColumn Header="St." Width="32">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding StatusIcon}"
                                                               Foreground="{Binding StatusColor, Converter={StaticResource HexColor}}"
                                                               FontSize="13"
                                                               HorizontalAlignment="Center"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Sprite Name" Width="210">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding SpriteName}"
                                                               Foreground="#0D1F1C"
                                                               FontFamily="Segoe UI"
                                                               FontSize="12"
                                                               TextTrimming="CharacterEllipsis"
                                                               ToolTip="{Binding SpriteName}"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Message" Width="360">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Message}"
                                                               Foreground="#2A4840"
                                                               FontFamily="Consolas"
                                                               FontSize="11"
                                                               TextTrimming="CharacterEllipsis"
                                                               ToolTip="{Binding Message}"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Source Asset" Width="210">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding AssetFilePath}"
                                                               Foreground="#6AA89A"
                                                               FontFamily="Consolas"
                                                               FontSize="10.5"
                                                               TextTrimming="CharacterEllipsis"
                                                               ToolTip="{Binding AssetFilePath}"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Border>
                    </Grid>
                </Grid>

                <!-- ══════════ STATUS BAR ══════════ -->
                <Border Grid.Row="2"
                        Background="#B8D8CC"
                        BorderBrush="#6AA89A"
                        BorderThickness="0,1,0,0"
                        Padding="18,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Mint dot + status text -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="6" Height="6" Fill="#086048" Margin="0,0,7,0">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#086048" BlurRadius="4" Opacity="0.70" ShadowDepth="0"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            <TextBlock Text="{Binding StatusText}"
                                       Foreground="#40605A"
                                       FontFamily="Consolas"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <TextBlock Grid.Column="1"
                                   Text="Atlas Sprite Revert Tool  v1.0"
                                   Foreground="#90C4BA"
                                   FontFamily="Segoe UI"
                                   FontSize="11"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

    </Grid>
</Window>
